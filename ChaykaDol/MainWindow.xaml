<Window x:Class="ChaykaDol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Чайка" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Дети" Width="100" Margin="5" Click="BtnChildren_Click"/>
            <Button Content="Отряды" Width="100" Margin="5" Click="BtnGroups_Click"/>
            <Button Content="Заявки" Width="100" Margin="5" Click="BtnRequests_Click"/>
            <Button Content="Мероприятия" Width="100" Margin="5" Click="BtnEvents_Click"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>